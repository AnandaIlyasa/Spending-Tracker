.env
.env*
assets/.env
assets/.env*

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
# Ignore generated iOS assets but keep the folder structure
ios/Runner/Assets.xcassets/*
!ios/Runner/Assets.xcassets/.gitkeep

# Ignore generated Android mipmap icons but keep the folders
android/app/src/main/res/mipmap-mdpi/*
!android/app/src/main/res/mipmap-mdpi/.gitkeep
android/app/src/main/res/mipmap-hdpi/*
!android/app/src/main/res/mipmap-hdpi/.gitkeep
android/app/src/main/res/mipmap-xhdpi/*
!android/app/src/main/res/mipmap-xhdpi/.gitkeep
android/app/src/main/res/mipmap-xxhdpi/*
!android/app/src/main/res/mipmap-xxhdpi/.gitkeep
android/app/src/main/res/mipmap-xxxhdpi/*
!android/app/src/main/res/mipmap-xxxhdpi/.gitkeep

